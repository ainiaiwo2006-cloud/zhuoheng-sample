# ZHUOHENG nginx reverse-proxy with security hardening.
# Save to /etc/nginx/sites-available/zhuoheng.conf and symlink to sites-enabled.
# Then run: certbot --nginx -d zhuoheng.com -d www.zhuoheng.com

# Hide nginx version in Server: header and error pages
server_tokens off;

# Per-IP rate-limit zone (10MB ≈ 160k IPs)
limit_req_zone $binary_remote_addr zone=zhuoheng_general:10m rate=30r/s;
limit_req_zone $binary_remote_addr zone=zhuoheng_api:10m rate=2r/s;

# ── HTTP → HTTPS redirect ────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name zhuoheng.com www.zhuoheng.com;
    return 301 https://$host$request_uri;
}

# ── HTTPS app server ─────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name zhuoheng.com www.zhuoheng.com;

    # ── TLS hardening (Mozilla "Intermediate", Apr 2026) ──
    ssl_certificate     /etc/letsencrypt/live/zhuoheng.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/zhuoheng.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;
    # OCSP stapling
    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 1.1.1.1 8.8.8.8 valid=60s;
    resolver_timeout 5s;

    # ── Security response headers ─────────────────────────
    # HSTS — 1 year, include subdomains. After confirming everything is on
    # HTTPS, you may submit to https://hstspreload.org/ to add `preload`.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()" always;
    # Cross-origin policies (relax if you need cross-origin embeds):
    add_header Cross-Origin-Opener-Policy "same-origin" always;
    add_header Cross-Origin-Resource-Policy "same-origin" always;
    # CSP — start permissive (Next.js needs unsafe-inline for hydration scripts).
    # Tighten by switching to nonces once you stabilise.
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" always;

    # ── Compression + size limits ────────────────────────
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/javascript application/javascript application/json image/svg+xml;
    client_max_body_size 5M;            # was 20M; tighten — no feature uploads files
    client_body_buffer_size 128k;
    large_client_header_buffers 4 16k;

    # General per-IP rate limit (browsing)
    limit_req zone=zhuoheng_general burst=60 nodelay;

    # ── Static Next.js assets — long-lived cache ──────────
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_cache_valid 200 365d;
        add_header Cache-Control "public, max-age=31536000, immutable";
        # security headers still apply (always flag above)
        access_log off;
    }

    # ── API endpoints — tighter rate limit ────────────────
    location /api/ {
        limit_req zone=zhuoheng_api burst=10 nodelay;
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    # ── Block hidden files & common probes ────────────────
    location ~ /\.(env|git|htaccess|svn|DS_Store) {
        deny all;
        return 404;
    }
    location ~* \.(sql|bak|backup|swp|old|orig|conf|ini|log)$ {
        deny all;
        return 404;
    }

    # ── Everything else → Next.js ─────────────────────────
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
